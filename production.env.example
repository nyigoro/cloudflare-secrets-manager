MY_SECRET_KEY=replace-with-production-secret
DATABASE_URL=postgres://app_user:replace_with_db_secret@prod-db.example.com:5432/app
JWT_SECRET=replace-with-a-long-random-production-jwt-secret
API_TOKEN=replace-with-production-api-token
