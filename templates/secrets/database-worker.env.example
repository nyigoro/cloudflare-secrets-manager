# Database-backed Worker secrets.
# Copy to production.env or staging.env.

DATABASE_URL=postgres://app_user:replace_with_db_secret@db.example.com:5432/app
DATABASE_READONLY_URL=postgres://readonly_user:replace_with_db_secret@db.example.com:5432/app
JWT_SECRET=replace-with-long-random-jwt-secret
MIGRATION_TOKEN=replace-with-internal-migration-token
