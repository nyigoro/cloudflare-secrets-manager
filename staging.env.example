# ============================================================
#  Cloudflare Workers - Staging Secrets
#  Copy this file to staging.env and replace placeholders.
#  Never commit staging.env.
# ============================================================

MY_SECRET_KEY=replace-with-staging-secret
DATABASE_URL=postgres://app_user:replace_with_db_secret@staging-db.example.com:5432/app
JWT_SECRET=replace-with-a-long-random-staging-jwt-secret
API_TOKEN=replace-with-staging-api-token
